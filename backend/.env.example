# ╔══════════════════════════════════════════════════════╗
# ║         BACKEND ENVIRONMENT CONFIGURATION            ║
# ║  Copy file này thành .env và điền giá trị thực       ║
# ╚══════════════════════════════════════════════════════╝

# ── Server ────────────────────────────────────────────────────────────────────
PORT=5000

# ── Database (PostgreSQL / TimescaleDB) ───────────────────────────────────────
# Chạy local (npm run dev):  dùng localhost
# Chạy Docker Compose:       dùng tên service "db"
DATABASE_URL=postgres://admin:yourpassword@localhost:5432/telehealth_system

# ── MQTT Broker ───────────────────────────────────────────────────────────────
# OPTION A – Mosquitto local (Docker Compose)
#   Chạy local:         MQTT_BROKER=mqtt://localhost:1883
#   Chạy Docker Compose: MQTT_BROKER=mqtt://mosquitto:1883  ← override trong compose
MQTT_BROKER=mqtt://localhost:1883
MQTT_SUBSCRIBE_TOPIC=vitals/+/data
MQTT_USERNAME=server
MQTT_PASSWORD=your_mqtt_server_password
MQTT_DEVICE_USERNAME=device
MQTT_DEVICE_PASSWORD=your_mqtt_device_password
#
# OPTION B – HiveMQ Cloud (TLS, public internet, free tier)
#   1. Đăng ký tại: https://console.hivemq.cloud
#   2. Tạo cluster → lấy hostname
#   3. Tạo credentials: user "server" + user "device"
#MQTT_BROKER=mqtts://YOUR_CLUSTER_ID.s1.eu.hivemq.cloud:8883
#MQTT_USERNAME=server
#MQTT_PASSWORD=your_hivemq_server_password

# ── Authentication ─────────────────────────────────────────────────────────────
# Dùng openssl hoặc: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=change_this_to_a_random_256bit_secret_min_32_chars

# ── Email (SMTP) ───────────────────────────────────────────────────────────────
# Gmail: Bật 2FA → Tạo App Password tại myaccount.google.com/apppasswords
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_gmail@gmail.com
SMTP_PASS=your_16char_app_password
EMAIL_FROM="IoT Telehealth <your_gmail@gmail.com>"

# ── CORS ───────────────────────────────────────────────────────────────────────
# URL mà browser dùng để truy cập frontend
# Local / Docker local:  http://localhost:3001
# Server thật:           https://yourdomain.com
FRONTEND_URL=http://localhost:3001

# ── MQTT Simulator (Python script) ────────────────────────────────────────────
# Script: backend/scripts/simulate_device_mqtt.py
# Chế độ đơn thiết bị:
SIM_DEVICE_ID=DEV_01
# Chế độ nhiều thiết bị (cách 1): danh sách thiết bị phân tách bằng dấu phẩy
# SIM_DEVICES=DEV_01,DEV_02,DEV_03
# Chế độ patient -> nhiều devices (cách 2):
# SIM_PATIENT_DEVICES=PAT_01:DEV_01|DEV_02,PAT_02:DEV_03
# Topic template (mặc định tự dùng vitals/<device_id>/data)
# SIM_TOPIC=vitals/{device_id}/data
SIM_MQTT_USER=device
# SIM_MQTT_PASS=your_mqtt_device_password
SIM_INTERVAL=1
SIM_ABNORMAL_RATE=0.1
SIM_DEVICE_STAGGER_MS=0
# SIM_SESSION_ID=